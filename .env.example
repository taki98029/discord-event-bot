# スラッシュコマンド登録（npm run register-commands）用の環境変数サンプル。
# このファイルを .env にコピーして実値を設定してください（.env は .gitignore 済み）。
# 通常は管理画面の「コマンドを登録」ボタンで登録できるため、このファイルは CLI 登録時のみ必要です。

# Discord Bot Token（Discord Developer Portal → Bot）
DISCORD_BOT_TOKEN=your_bot_token_here

# Discord Application ID（Discord Developer Portal → General Information）
DISCORD_APPLICATION_ID=your_application_id_here

# 任意: 指定するとそのサーバーへ即時登録（テスト向け）。未指定はグローバル登録（反映に最大1時間）。
DISCORD_GUILD_ID=
