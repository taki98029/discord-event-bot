# 環境変数サンプル
# .env ファイルを作成してこの内容をコピーし、実際の値を設定してください

# =====================================
# Discord設定
# =====================================

# Discord Application Public Key (Discord Developer Portalから取得)
DISCORD_PUBLIC_KEY=your_public_key_here

# Discord Application ID (スラッシュコマンド登録に使用, Discord Developer Portalから取得)
DISCORD_APPLICATION_ID=your_application_id_here

# Discord Bot Token (メッセージ送信に使用)
DISCORD_BOT_TOKEN=your_bot_token_here

# Discord Channel ID (メッセージを送信するチャンネル)
DISCORD_CHANNEL_ID=your_channel_id_here

# =====================================
# Google Sheets設定
# =====================================

# スプレッドシートID (URLから取得: https://docs.google.com/spreadsheets/d/{このID}/edit)
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# サービスアカウントのJSON鍵 (1行に圧縮して貼り付け)
# 取得方法:
# 1. Google Cloud Console → 「サービスアカウント」作成
# 2. JSON形式でキーをダウンロード
# 3. ファイル内容を1行にして貼り付け
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# =====================================
# オプション
# =====================================

# Cron Job認証用シークレット (任意の文字列)
# 設定するとCronエンドポイントに認証が必要になります
CRON_SECRET=your_cron_secret_here