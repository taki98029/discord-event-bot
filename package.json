{
  "name": "choiemu-event-bot",
  "version": "6.0.0",
  "description": "Discord Event Master Bot - Cloudflare Workers + D1 implementation with admin UI",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate:local": "wrangler d1 migrations apply choiemu-event-bot-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply choiemu-event-bot-db --remote",
    "register-commands": "node scripts/register-commands.js",
    "migrate-from-sheets": "node scripts/migrate-from-sheets.mjs"
  },
  "dependencies": {
    "discord-interactions": "^4.1.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.0",
    "@cloudflare/workers-types": "^4.20250101.0",
    "dotenv": "^17.3.1",
    "googleapis": "^144.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "wrangler": "^3.95.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
